# Telegram
BOT_TOKEN=123456:ABC-DEF

# Webhook (for production) or Polling (for local)
USE_POLLING=true
WEBHOOK_HOST=https://your-domain.com
WEBHOOK_PATH=/webhook
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080

# Supabase (подключение к БД только через API, без DATABASE_URL)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key

# Яндекс.Диск: админ создаёт категорию → папка на Диске; загрузчик грузит видео в папку категории; после ссылки от получателя — видео удаляется.
# Получить токен: https://oauth.yandex.ru/ (см. инструкцию YANDEX_DISK.md)
YANDEX_DISK_TOKEN=
YANDEX_DISK_ROOT_PATH=/bot_videos

# Misc
RATE_LIMIT_SECONDS=2
LOG_LEVEL=INFO
# Колонка названия в таблице topics: keyword, title или name
TOPIC_NAME_COLUMN=keyword
